   HAUSA TRANSLATION
══════════════════════════════════════════ */
let _hausaTimer=null;
function autoSaveHausa(){
  clearTimeout(_hausaTimer);
  _hausaTimer=setTimeout(()=>{
    const n=getActive(); if(!n) return;
    n.title_hausa=document.getElementById('fHausaTitle').value.trim();
    n.summary_hausa=document.getElementById('fHausaSummary').value.trim();
    n.updatedAt=new Date().toISOString();
    const hdr=document.getElementById('ncHausaTitle');
    if(n.title_hausa){hdr.textContent=n.title_hausa;hdr.style.display='block'}
    else hdr.style.display='none';
    saveGraph();
  },700);
}

async function translateToHausa(){
  if(!getApiKey()){toast('⚠ Add your API key in ⚙ API settings');openSettings();return}
  const n=getActive(); if(!n) return;
  const btn=document.getElementById('translateBtn'), status=document.getElementById('hausaStatus');
  btn.disabled=true; btn.innerHTML='<span class="spin" style="color:var(--amber)"></span> Fassara...'; status.textContent='';
  try{
    const res=await fetch(getApiEndpoint(),{
      method:'POST', headers:buildHeaders(),
      body:JSON.stringify({
        model:'claude-haiku-4-5-20251001', max_tokens:500,
        system:'You are a Hausa language expert and Northern Nigerian cultural translator. Translate tech/business concepts into natural, idiomatic Hausa that an Arewa community member would understand. Return ONLY valid JSON, no markdown.',
        messages:[{role:'user',content:`Translate to Hausa:\n\nTitle: "${n.title}"\nSummary: "${n.summary}"\n\nReturn ONLY: {"title_hausa":"<hausa title>","summary_hausa":"<hausa 2-3 sentences>"}`}]
      })
    });
    const data=await res.json();
    if(!res.ok) throw new Error(data.error?.message||`Error ${res.status}`);
    const parsed=JSON.parse((data.content?.[0]?.text||'{}').replace(/```json|```/g,'').trim());
    document.getElementById('fHausaTitle').value=parsed.title_hausa||'';
    document.getElementById('fHausaSummary').value=parsed.summary_hausa||'';
    n.title_hausa=parsed.title_hausa||'';
    n.summary_hausa=parsed.summary_hausa||'';
    n.updatedAt=new Date().toISOString();
    autoNote(n,'AI generated Hausa translation');
    const hdr=document.getElementById('ncHausaTitle');
    if(n.title_hausa){hdr.textContent=n.title_hausa;hdr.style.display='block'}
    saveGraph(); renderNodeList();
    status.textContent='✓ Done'; status.style.color='var(--green)';
    toast('🌙 Hausa translation saved');
  }catch(err){
    status.textContent=err.message||'⚠ Failed'; status.style.color='var(--red)';
    toast('⚠ Translation failed');
  }finally{
    btn.disabled=false; btn.innerHTML='✦ AI Fassara';
    setTimeout(()=>{status.textContent=''},4000);
  }
}

