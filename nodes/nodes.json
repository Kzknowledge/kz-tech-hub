  if(!n.notes)      n.notes=[];
  if(!n.title_hausa)  n.title_hausa='';
  if(!n.summary_hausa) n.summary_hausa='';
  if(!n.createdAt)  n.createdAt=new Date().toISOString();
  if(!n.updatedAt)  n.updatedAt=new Date().toISOString();
  if(n.aiGenerated===undefined) n.aiGenerated=false;
  // sync edges → related
  graphData.links.forEach(l=>{
    const s=l.source?.id||l.source, t=l.target?.id||l.target;
    if(s===n.id && !n.related.includes(t)) n.related.push(t);
    if(t===n.id && !n.related.includes(s)) n.related.push(s);
  });
  return n;
}

function fmtDate(iso){
  if(!iso) return '—';
  const d=new Date(iso), now=new Date(), df=now-d;
  if(df<60000) return 'just now';
  if(df<3600000) return Math.floor(df/60000)+'m ago';
  if(df<86400000) return Math.floor(df/3600000)+'h ago';
  return d.toLocaleDateString('en-NG',{day:'numeric',month:'short'});
}

function delay(ms){ return new Promise(r=>setTimeout(r,ms)) }

function toast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg; t.classList.add('show');
  clearTimeout(t._t); t._t=setTimeout(()=>t.classList.remove('show'),2600);
}

function escHtml(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;') }

function openResource(url){ window.open(url,'_blank','noopener') }

/* ══════════════════════════════════════════
   STATS + PIPELINE
══════════════════════════════════════════ */
function updateStats(){
  document.getElementById('statNodes').textContent=graphData.nodes.length;
  document.getElementById('statEdges').textContent=graphData.links.length;
  document.getElementById('statActions').textContent=actionCount;
  document.getElementById('nodeCount').textContent=graphData.nodes.filter(n=>currentFilter==='all'||n.category===currentFilter).length;
}

function pipe(step,state){ const el=document.getElementById('ps-'+step); if(el) el.className='pipe-step '+state }
function pi(n,state){
  const d=document.getElementById('pi'+n),t=document.getElementById('pi'+n+'t');
  const labels={1:'Ingest ready',2:'Embedding',3:'Building graph',4:'Linking edges',5:'AI layer ready'};
  if(d){d.className='pidot '+state; if(t) t.textContent=(state==='active'?'⟳ ':state==='done'?'✓ ':'')+labels[n]}
}
function feedback(msg){ document.getElementById('feedbackMsg').textContent=msg; setTimeout(()=>document.getElementById('feedbackMsg').textContent='Graph OS ready',5000) }

/* ══════════════════════════════════════════
   FILTER + SEARCH
══════════════════════════════════════════ */
function setFilter(el,cat){
  document.querySelectorAll('.ftab').forEach(t=>t.classList.remove('on'));
  el.classList.add('on'); currentFilter=cat;
  renderNodeList(); updateStats();
}

function filterNodes(){ renderNodeList() }

/* ══════════════════════════════════════════
   NODE LIST
══════════════════════════════════════════ */
function renderNodeList(){
  const list=document.getElementById('nodeList');
  const q=document.getElementById('searchInput').value.toLowerCase().trim();
  let nodes=graphData.nodes.filter(n=>{
    if(currentFilter!=='all' && n.category!==currentFilter) return false;
    if(q && !n.title.toLowerCase().includes(q) && !(n.title_hausa||'').toLowerCase().includes(q)) return false;
    return true;
  });
  if(!nodes.length){
    list.innerHTML='<div style="font-size:10px;color:var(--ink3);text-align:center;padding:14px 0">No nodes found</div>';
    return;
  }
  list.innerHTML=nodes.slice().reverse().map(n=>{
    enrichNode(n);
    const c=CAT_COLORS[n.category]||CAT_COLORS.insight;
    const lnks=graphData.links.filter(l=>(l.source===n.id||l.source?.id===n.id||l.target===n.id||l.target?.id===n.id)).length;
    const isNew=n.createdAt && (Date.now()-new Date(n.createdAt).getTime())<86400000*7;
    return `<div class="nitem ${n.id===selectedId?'sel':''}" onclick="selectNode('${n.id}')">
      <div class="ndot" style="background:${c};box-shadow:0 0 5px ${c}55"></div>
      <div style="min-width:0">
        <div class="nitem-title">${n.title}${isNew?' <span style="font-size:8px;color:var(--green);font-weight:600">NEW</span>':''}</div>
        <div class="nitem-meta">${TOPICS[n.category]?.label||n.category} · ⚡${n.leverage} · ${lnks} link${lnks!==1?'s':''}</div>
        ${n.title_hausa?`<div class="nitem-hausa">${n.title_hausa}</div>`:''}
      </div>
    </div>`;
  }).join('');
}

/* ══════════════════════════════════════════
   NODE CARD RENDER
══════════════════════════════════════════ */
function renderNodeCard(node){
  enrichNode(node);
  const topic=TOPICS[node.category]||TOPICS.insight;
  const status=STATUSES.find(s=>s.id===node.status)||STATUSES[0];
  const stepIdx=STATUSES.findIndex(s=>s.id===node.status);

  document.getElementById('nodeEmpty').style.display='none';
  document.getElementById('nodeCardWrap').classList.add('visible');

  const glyph=document.getElementById('ncGlyph');
  glyph.textContent=topic.icon;
  glyph.style.background=CAT_COLORS[node.category]+'18';
  glyph.style.borderColor=CAT_COLORS[node.category]+'28';

  document.getElementById('ncTitle').textContent=node.title;

  const hausaHdr=document.getElementById('ncHausaTitle');
  if(node.title_hausa){hausaHdr.textContent=node.title_hausa;hausaHdr.style.display='block'}
  else hausaHdr.style.display='none';

  document.getElementById('ncMeta').innerHTML=`
    <span class="cat-badge ${topic.cls}">${topic.icon} ${topic.label}</span>
    <span class="nc-meta-txt">⚡${node.leverage}/5</span>
    <span class="nc-meta-txt">${node.related.length} link${node.related.length!==1?'s':''}</span>
    <span class="nc-meta-txt">${(node.notes||[]).length} note${(node.notes||[]).length!==1?'s':''}</span>`;

  document.getElementById('fSummary').value=node.summary||'';
  document.getElementById('fSummary').readOnly=true;
  document.getElementById('fSummary').onclick=function(){this.readOnly=false;this.focus()};
  document.getElementById('fSummary').onblur=function(){node.summary=this.value;node.updatedAt=new Date().toISOString();this.readOnly=true;saveGraph()};

  document.getElementById('fHausaTitle').value=node.title_hausa||'';
  document.getElementById('fHausaSummary').value=node.summary_hausa||'';

  const tc=CAT_COLORS[node.category];
  document.getElementById('fTopicWrap').innerHTML=`
    <div class="topic-badge ${topic.cls}" style="background:${tc}14;border-color:${tc}35">
      <span>${topic.icon}</span>
      <select class="topic-sel ${topic.cls}" onchange="changeTopic(this.value)" style="color:${tc}">
        ${Object.entries(TOPICS).map(([k,v])=>`<option value="${k}" ${k===node.category?'selected':''}>${v.label}</option>`).join('')}
      </select>
    </div>`;

  renderRelated(node);

  const s=node.leverage;
  document.getElementById('fLevNum').textContent=s;
  document.getElementById('fLevNum').style.color=LEV_COLORS[s];
  document.getElementById('fLevFill').style.width=(s/5*100)+'%';
  document.getElementById('fLevFill').style.background=`linear-gradient(90deg,${LEV_COLORS[s]},${LEV_COLORS[s]}cc)`;
  document.getElementById('fLevFill').style.boxShadow=`0 0 5px ${LEV_COLORS[s]}44`;
  document.getElementById('fLevLbl').textContent=LEV_LABELS[s];

  const sb=document.getElementById('fStatusBadge');
  sb.style.color=status.color;
  document.getElementById('fStatusDot').style.color=status.color;
  document.getElementById('fStatusTxt').textContent=status.label;
  document.getElementById('statusMenu').innerHTML=STATUSES.map(st=>`
    <div class="sopt" onclick="setStatus('${st.id}')">
      <div class="sopt-dot" style="background:${st.color};box-shadow:0 0 4px ${st.color}55"></div>
      <span>${st.label}</span><span class="sopt-desc">${st.desc}</span>
    </div>`).join('');

  document.getElementById('fSteps').innerHTML=STATUSES.map((st,i)=>{
    const done=i<stepIdx, active=i===stepIdx;
    return `<div class="stp"><div class="stp-dot ${done?'done':active?'active':''}" title="${st.label}"></div>${i<STATUSES.length-1?`<div class="stp-line ${done?'done':''}"></div>`:''}</div>`;
  }).join('');

  renderNotes(node);
  document.getElementById('fCreated').textContent=fmtDate(node.createdAt);
  document.getElementById('fUpdated').textContent=fmtDate(node.updatedAt);
  document.getElementById('fAiFlag').style.display=node.aiGenerated?'flex':'none';
}

function renderRelated(node){
  const relEl=document.getElementById('fRelated');
  const others=graphData.nodes.filter(n=>n.id!==node.id&&!node.related.includes(n.id));
  relEl.innerHTML=(node.related||[]).map(rid=>{
    const rn=getNode(rid); if(!rn) return '';
    const rc=CAT_COLORS[rn.category];
    const short=rn.title.length>22?rn.title.slice(0,20)+'…':rn.title;
    return `<div class="rnode" onclick="selectNode('${rid}')"><div class="rdot" style="background:${rc}"></div><span>${short}</span><button class="unlink" title="Unlink" onclick="unlinkNode(event,'${rid}')">×</button></div>`;
  }).join('');
  if(others.length){
    relEl.innerHTML+=`<div class="rel-picker" id="pickerWrap"><button class="add-rel" onclick="togglePicker(event)">+ Link</button><div class="related-picker-menu" id="pickerMenu">${others.map(n=>{const t=TOPICS[n.category];return `<div class="picker-item" onclick="linkNode('${n.id}')"><div class="rdot" style="background:${CAT_COLORS[n.category]}"></div><span>${t.icon} ${n.title.length>30?n.title.slice(0,28)+'…':n.title}</span></div>`}).join('')}</div></div>`;
  }
}

function renderNotes(node){
  const list=document.getElementById('notesList');
  const notes=(node.notes||[]).slice().reverse();
  if(!notes.length){list.innerHTML='<div class="notes-empty">No notes yet. Add observations or decisions.</div>';return}
  list.innerHTML=notes.map(note=>`
    <div class="note-item ${note.type==='auto'?'auto':''}">
      <div class="note-dot ${note.type==='auto'?'auto':'manual'}"></div>
      <div class="note-body">
        <div class="note-text">${escHtml(note.text)}</div>
        <div class="note-time">${fmtDate(note.createdAt)}${note.type==='auto'?' · auto':''}</div>
      </div>
      ${note.type!=='auto'?`<button class="note-del" onclick="deleteNote('${note.id}')" title="Delete">×</button>`:''}
    </div>`).join('');
}

/* ══════════════════════════════════════════
   NODE SELECTION
══════════════════════════════════════════ */
function selectNode(id){
  selectedId=id;
  const node=getNode(id); if(!node) return;
  enrichNode(node);
  highlightNode(id);
  renderNodeCard(node);
  renderNodeList();
  pipe('explore','done'); pipe('act','active');
}

