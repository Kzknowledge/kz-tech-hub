<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="KZ Knowledge Graph OS — AI-powered knowledge management for Kimiyyar Zahiri Tech Hub">
<meta name="theme-color" content="#C47B18">
<title>KZ · Knowledge Graph OS v4 · Kimiyyar Zahiri</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,400&family=Scheherazade+New:wght@400;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/d3/7.8.5/d3.min.js"></script>
<style>
/* ═══════════════════════════════════════
   DESIGN TOKENS — WHITE / AMBER EDITION
═══════════════════════════════════════ */
:root {
  --bg:       #FFFFFF;
  --s1:       #F9F6F1;
  --s2:       #F2EDE4;
  --s3:       #E9E2D6;
  --s4:       #DDD4C4;
  --graph-bg: #F5F1EA;

  --amber:    #C47B18;
  --amber2:   #E09020;
  --amber3:   #F5B040;
  --amber-d:  rgba(196,123,24,.10);
  --amber-g:  rgba(196,123,24,.30);
  --amber-b:  rgba(196,123,24,.20);

  --sky:      #1672B8;
  --sky-d:    rgba(22,114,184,.10);
  --green:    #0F8A52;
  --green-d:  rgba(15,138,82,.10);
  --purple:   #6840C8;
  --purple-d: rgba(104,64,200,.10);
  --red:      #B82828;
  --red-d:    rgba(184,40,40,.10);
  --teal:     #0A8898;
  --teal-d:   rgba(10,136,152,.10);

  --ink:      #1A1410;
  --ink2:     rgba(26,20,16,.68);
  --ink3:     rgba(26,20,16,.40);
  --ink4:     rgba(26,20,16,.12);
  --line:     rgba(26,20,16,.08);
  --line2:    rgba(196,123,24,.22);

  --mono:     'DM Mono', monospace;
  --head:     'Syne', sans-serif;
  --arab:     'Scheherazade New', serif;
  --ease:     cubic-bezier(.4,0,.2,1);
  --panel-w:  320px;
  --nav-h:    50px;
  --hub-h:    42px;
  --shadow:   0 1px 3px rgba(26,20,16,.08), 0 4px 16px rgba(26,20,16,.06);
  --shadow-md:0 4px 24px rgba(26,20,16,.12);
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden}
body{font-family:var(--mono);background:var(--bg);color:var(--ink);display:flex;flex-direction:column}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--line2);border-radius:2px}

/* ═══════════════════════════════
   NAV
═══════════════════════════════ */
.nav{
  height:var(--nav-h);min-height:var(--nav-h);
  position:sticky;top:0;z-index:100;
  display:flex;align-items:center;padding:0 16px;gap:12px;
  background:#fff;border-bottom:1px solid var(--line2);
  box-shadow:var(--shadow);
}
.nav-brand{display:flex;align-items:center;gap:9px;flex-shrink:0}
.kz-mark{
  width:32px;height:32px;border-radius:7px;
  background:linear-gradient(135deg,var(--amber2),var(--amber));
  color:#fff;font-family:var(--head);font-weight:800;font-size:13px;
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 2px 8px var(--amber-g);
}
.brand-main{font-family:var(--head);font-weight:700;font-size:12px;letter-spacing:.6px;color:var(--ink)}
.brand-sub{font-family:var(--arab);font-size:11px;color:var(--amber);margin-top:1px}
.nav-pipe{display:flex;align-items:center;gap:3px;flex:1;justify-content:center;overflow-x:auto}
.pipe-step{font-size:10px;font-weight:500;letter-spacing:.3px;color:var(--ink3);padding:3px 8px;border-radius:4px;white-space:nowrap;transition:all .25s}
.pipe-step.active{color:var(--amber);background:var(--amber-d)}
.pipe-step.done{color:var(--green)}
.pipe-arrow{color:var(--ink3);font-size:9px}
.nav-right{display:flex;align-items:center;gap:6px;flex-shrink:0;margin-left:auto}
.nav-stat{font-size:10px;color:var(--ink3);padding:3px 8px;border:1px solid var(--ink4);border-radius:5px}
.nav-stat b{color:var(--amber)}
.live-dot{width:7px;height:7px;border-radius:50%;background:var(--green);box-shadow:0 0 7px var(--green);animation:blink 2s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.25}}
.nav-btn{
  padding:5px 10px;border-radius:5px;border:1px solid var(--line2);
  background:transparent;color:var(--ink3);font-family:var(--mono);font-size:10px;
  cursor:pointer;transition:all .15s;white-space:nowrap;
}
.nav-btn:hover{background:var(--s2);color:var(--ink);border-color:var(--amber-b)}
.nav-btn.amber{border-color:var(--amber-b);color:var(--amber);background:var(--amber-d)}
.nav-btn.amber:hover{background:rgba(196,123,24,.18)}

/* ═══════════════════════════════
   WORKSPACE
═══════════════════════════════ */
.workspace{flex:1;display:grid;grid-template-columns:var(--panel-w) 1fr var(--panel-w);overflow:hidden}

/* ═══════════════════════════════
   LEFT PANEL
═══════════════════════════════ */
.panel-left{background:var(--s1);border-right:1px solid var(--line2);display:flex;flex-direction:column;overflow:hidden}
.panel-hdr{
  padding:11px 14px 9px;border-bottom:1px solid var(--line2);flex-shrink:0;
  font-size:10px;font-weight:600;letter-spacing:1.8px;text-transform:uppercase;
  color:var(--ink3);display:flex;align-items:center;gap:6px;
}
.panel-hdr-accent{color:var(--amber)}
.panel-body{flex:1;overflow-y:auto;padding:12px}

/* Search */
.search-wrap{position:relative;margin-bottom:10px}
.search-input{
  width:100%;background:#fff;border:1px solid var(--line2);border-radius:7px;
  padding:8px 10px 8px 30px;font-family:var(--mono);font-size:11px;color:var(--ink);
  outline:none;transition:border-color .2s;
}
.search-input:focus{border-color:var(--amber)}
.search-icon{position:absolute;left:9px;top:50%;transform:translateY(-50%);font-size:12px;color:var(--ink3);pointer-events:none}

/* Filter tabs */
.filter-tabs{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:10px}
.ftab{
  font-size:9px;padding:3px 8px;border-radius:4px;cursor:pointer;
  border:1px solid var(--line2);color:var(--ink3);background:transparent;
  font-family:var(--mono);transition:all .15s;font-weight:500;
}
.ftab:hover{border-color:var(--amber-b);color:var(--amber)}
.ftab.on{background:var(--amber-d);border-color:var(--amber-b);color:var(--amber)}

/* Node list */
.nodelist-hdr{font-size:9px;letter-spacing:1px;text-transform:uppercase;color:var(--ink3);margin-bottom:6px;display:flex;align-items:center;justify-content:space-between}
.nitem{
  display:flex;align-items:flex-start;gap:7px;padding:8px;border-radius:7px;
  cursor:pointer;transition:all .15s;border:1px solid transparent;margin-bottom:3px;
}
.nitem:hover{background:#fff;border-color:var(--line2);box-shadow:var(--shadow)}
.nitem.sel{background:#fff;border-color:var(--amber-b);box-shadow:var(--shadow)}
.ndot{width:7px;height:7px;border-radius:50%;flex-shrink:0;margin-top:3px}
.nitem-title{font-size:11px;font-weight:600;color:var(--ink);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.nitem-meta{font-size:9px;color:var(--ink3);margin-top:1px}
.nitem-hausa{font-family:var(--arab);font-size:10px;color:var(--amber);direction:rtl;margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

.divider{height:1px;background:var(--line2);margin:12px 0}

/* Ingest */
.ilabel{font-size:9px;font-weight:600;letter-spacing:1px;color:var(--ink3);text-transform:uppercase;margin-bottom:5px;display:flex;align-items:center;gap:4px}
.itextarea{
  width:100%;background:#fff;border:1px solid var(--line2);border-radius:7px;
  padding:9px 11px;color:var(--ink);font-family:var(--mono);font-size:11px;
  resize:none;height:90px;outline:none;transition:border-color .2s;line-height:1.6;
}
.itextarea:focus{border-color:var(--amber)}
.itextarea::placeholder{color:var(--ink3)}
.tag-row{display:flex;gap:4px;flex-wrap:wrap;margin:7px 0}
.mtag{
  font-size:9px;padding:2px 8px;border-radius:4px;cursor:pointer;
  border:1px solid;transition:all .15s;font-weight:500;font-family:var(--mono);
}
.mt-tech{color:var(--sky);border-color:rgba(22,114,184,.3)}
.mt-tech.sel,.mt-tech:hover{background:var(--sky-d);border-color:var(--sky)}
.mt-trust{color:var(--green);border-color:rgba(15,138,82,.3)}
.mt-trust.sel,.mt-trust:hover{background:var(--green-d);border-color:var(--green)}
.mt-transform{color:var(--amber);border-color:rgba(196,123,24,.3)}
.mt-transform.sel,.mt-transform:hover{background:var(--amber-d);border-color:var(--amber)}
.mt-insight{color:var(--purple);border-color:rgba(104,64,200,.3)}
.mt-insight.sel,.mt-insight:hover{background:var(--purple-d);border-color:var(--purple)}
.ibtn{
  width:100%;padding:8px;border:none;border-radius:7px;
  background:var(--amber);color:#fff;font-family:var(--head);font-weight:700;
  font-size:11px;letter-spacing:.8px;cursor:pointer;transition:all .18s var(--ease);
  display:flex;align-items:center;justify-content:center;gap:5px;margin-top:7px;
}
.ibtn:hover{background:var(--amber2);box-shadow:0 4px 16px var(--amber-g)}
.ibtn:disabled{opacity:.5;cursor:not-allowed}

/* Resources */
.res-hdr{font-size:9px;letter-spacing:1px;text-transform:uppercase;color:var(--ink3);margin-bottom:7px;display:flex;align-items:center;justify-content:space-between}
.res-card{
  background:#fff;border:1px solid var(--line2);border-radius:8px;
  padding:10px 11px;margin-bottom:7px;cursor:pointer;transition:all .15s;
  display:flex;align-items:flex-start;gap:9px;
}
.res-card:hover{border-color:var(--amber-b);box-shadow:var(--shadow)}
.res-icon{font-size:18px;flex-shrink:0}
.res-name{font-size:11px;font-weight:700;color:var(--ink);margin-bottom:2px;font-family:var(--head)}
.res-desc{font-size:10px;color:var(--ink3);line-height:1.5}
.res-tag{font-size:9px;color:var(--amber);font-weight:600;margin-top:4px;display:block}

/* ═══════════════════════════════
   CENTER GRAPH
═══════════════════════════════ */
.graph-center{position:relative;overflow:hidden;background:var(--graph-bg)}
#graphSvg{width:100%;height:100%;cursor:grab}
#graphSvg:active{cursor:grabbing}
.node circle{stroke-width:1.8;cursor:pointer}
.node text{fill:var(--ink);font-family:var(--mono);font-size:10px;pointer-events:none;font-weight:500}
.link{stroke-opacity:.35;stroke-width:1.5}

/* Grid dots on graph */
.graph-center::before{
  content:'';position:absolute;inset:0;pointer-events:none;
  background-image:radial-gradient(circle,rgba(196,123,24,.15) 1px,transparent 1px);
  background-size:28px 28px;
}

.graph-empty{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;pointer-events:none}
.graph-empty-icon{font-size:42px;opacity:.3}
.graph-empty-txt{font-size:12px;color:var(--ink3);text-align:center;max-width:220px;line-height:1.65}

.graph-toolbar{
  position:absolute;bottom:14px;left:50%;transform:translateX(-50%);
  display:flex;gap:4px;background:#fff;border:1px solid var(--line2);
  border-radius:8px;padding:4px;box-shadow:var(--shadow-md);
}
.tb-btn{
  padding:5px 11px;border-radius:5px;background:transparent;border:none;
  color:var(--ink3);font-family:var(--mono);font-size:10px;cursor:pointer;transition:all .15s;
}
.tb-btn:hover{background:var(--s2);color:var(--ink)}
.tb-btn.on{background:var(--amber-d);color:var(--amber)}

.graph-legend{
  position:absolute;top:12px;left:12px;
  background:rgba(255,255,255,.92);border:1px solid var(--line2);
  border-radius:7px;padding:9px 11px;backdrop-filter:blur(12px);box-shadow:var(--shadow);
}
.leg-row{display:flex;align-items:center;gap:5px;font-size:10px;color:var(--ink3);margin-bottom:3px}
.leg-row:last-child{margin-bottom:0}
.leg-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}

.pipe-indicator{
  position:absolute;top:12px;right:12px;
  background:rgba(255,255,255,.92);border:1px solid var(--line2);
  border-radius:7px;padding:9px 11px;backdrop-filter:blur(12px);
  font-size:10px;color:var(--ink3);max-width:165px;box-shadow:var(--shadow);
}
.pi-title{color:var(--amber);font-weight:600;letter-spacing:.8px;margin-bottom:5px}
.pi-row{display:flex;align-items:center;gap:5px;margin-bottom:2px}
.pidot{width:5px;height:5px;border-radius:50%;background:var(--ink3);flex-shrink:0}
.pidot.done{background:var(--green);box-shadow:0 0 4px var(--green)}
.pidot.active{background:var(--amber);box-shadow:0 0 5px var(--amber);animation:blink 1s infinite}

/* ═══════════════════════════════
   RIGHT PANEL
═══════════════════════════════ */
.panel-right{background:var(--s1);border-left:1px solid var(--line2);display:flex;flex-direction:column;overflow:hidden}
.node-empty{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;color:var(--ink3);font-size:11px;text-align:center;padding:20px}
.node-empty-icon{font-size:28px;opacity:.3}

.node-card-wrap{display:none;flex-direction:column;height:100%;overflow:hidden}
.node-card-wrap.visible{display:flex;animation:slideIn .25s var(--ease) both}
@keyframes slideIn{from{opacity:0;transform:translateX(8px)}to{opacity:1;transform:translateX(0)}}

/* Card header */
.nc-header{padding:13px 14px 10px;border-bottom:1px solid var(--line2);flex-shrink:0;background:#fff;position:relative}
.nc-header::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--amber),var(--amber2),transparent 70%)}
.nc-title-row{display:flex;align-items:flex-start;gap:8px;margin-bottom:6px}
.nc-glyph{width:34px;height:34px;border-radius:8px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:16px;border:1px solid var(--ink4)}
.nc-title{font-family:var(--head);font-weight:800;font-size:14px;color:var(--ink);line-height:1.2;flex:1;outline:none}
.nc-title[contenteditable=true]:focus{border-bottom:1px dashed var(--amber);padding-bottom:1px}
.nc-hausa{font-family:var(--arab);font-size:13px;color:var(--amber);direction:rtl;margin:3px 0;opacity:.9;padding-left:42px}
.edit-btn{width:24px;height:24px;border-radius:5px;background:var(--s2);border:1px solid var(--line2);color:var(--ink3);font-size:11px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s;flex-shrink:0}
.edit-btn:hover{color:var(--amber);border-color:var(--amber-b);background:var(--amber-d)}
.nc-meta{display:flex;align-items:center;gap:6px;flex-wrap:wrap}
.cat-badge{font-size:9px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;padding:2px 7px;border-radius:4px;border:1px solid}
.cat-tech{color:var(--sky);border-color:rgba(22,114,184,.3);background:var(--sky-d)}
.cat-trust{color:var(--green);border-color:rgba(15,138,82,.3);background:var(--green-d)}
.cat-transform{color:var(--amber);border-color:rgba(196,123,24,.3);background:var(--amber-d)}
.cat-insight{color:var(--purple);border-color:rgba(104,64,200,.3);background:var(--purple-d)}
.nc-meta-txt{font-size:9px;color:var(--ink3)}

/* Card body */
.nc-body{flex:1;overflow-y:auto;background:#fff}
.field{padding:11px 14px;border-bottom:1px solid var(--line);display:grid;grid-template-columns:100px 1fr;gap:8px;align-items:flex-start;transition:background .12s}
.field:last-child{border-bottom:none}
.field:hover{background:var(--s1)}
.field-label{font-size:9px;font-weight:600;letter-spacing:1.3px;text-transform:uppercase;color:var(--ink3);display:flex;align-items:center;gap:4px;padding-top:2px;flex-shrink:0}
.ficon{font-size:11px}
.field-val{flex:1;min-width:0}
.f-textarea{width:100%;background:transparent;border:none;outline:none;font-family:var(--mono);font-size:11.5px;color:var(--ink2);line-height:1.65;resize:none;padding:0}
.f-textarea:not([readonly]):focus{color:var(--ink);background:var(--s1);border-radius:5px;padding:5px 7px;margin:-5px -7px;border:1px solid var(--amber);width:calc(100% + 14px)}

/* Hausa field */
.hausa-field-wrap{display:flex;flex-direction:column;gap:6px}
.hausa-input{width:100%;background:var(--s1);border:1px solid var(--line2);border-radius:6px;padding:8px 10px;color:var(--amber);font-family:var(--arab);font-size:13px;direction:rtl;outline:none;resize:none;transition:border-color .15s;line-height:1.55}
.hausa-input:focus{border-color:var(--amber)}
.hausa-input::placeholder{color:var(--ink3);font-family:var(--arab);direction:rtl}
.hausa-btn{display:inline-flex;align-items:center;gap:4px;padding:4px 10px;border-radius:5px;font-size:10px;font-family:var(--mono);cursor:pointer;border:1px solid var(--amber-b);background:var(--amber-d);color:var(--amber);transition:all .15s}
.hausa-btn:hover{border-color:var(--amber);background:rgba(196,123,24,.18)}
.hausa-status{font-size:10px;color:var(--ink3)}

/* Topic badge */
.topic-badge{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:100px;font-size:10px;font-weight:600;border:1px solid;cursor:pointer}
.topic-sel{background:transparent;border:none;outline:none;font-family:var(--mono);font-size:10px;font-weight:600;cursor:pointer;padding:0}
.topic-sel option{background:#fff;color:var(--ink)}

/* Related nodes */
.related-list{display:flex;gap:5px;flex-wrap:wrap;align-items:center}
.rnode{display:flex;align-items:center;gap:4px;padding:3px 8px;border-radius:5px;font-size:10px;background:var(--s1);border:1px solid var(--line2);color:var(--ink2);cursor:pointer;transition:all .15s;position:relative}
.rnode:hover{border-color:var(--sky);color:var(--sky);background:var(--sky-d)}
.rdot{width:5px;height:5px;border-radius:50%;flex-shrink:0}
.rnode .unlink{margin-left:3px;font-size:10px;color:var(--ink3);opacity:0;transition:opacity .15s}
.rnode:hover .unlink{opacity:1}
.rel-picker{position:relative;display:inline-block}
.rel-picker-menu{display:none;position:absolute;top:calc(100% + 5px);left:0;background:#fff;border:1px solid var(--line2);border-radius:8px;z-index:60;min-width:220px;max-height:200px;overflow-y:auto;box-shadow:var(--shadow-md);padding:4px}
.rel-picker-menu.open{display:block;animation:menuIn .12s var(--ease)}
.picker-item{display:flex;align-items:center;gap:7px;padding:7px 11px;border-radius:5px;font-size:11px;color:var(--ink2);cursor:pointer;transition:background .1s}
.picker-item:hover{background:var(--s2);color:var(--ink)}
.add-rel{padding:3px 8px;border-radius:5px;font-size:10px;color:var(--ink3);border:1px dashed var(--line2);cursor:pointer;background:transparent;font-family:var(--mono);transition:all .15s}
.add-rel:hover{border-color:var(--green);color:var(--green)}

/* Leverage */
.lev-wrap{display:flex;align-items:center;gap:10px}
.lev-num{font-family:var(--head);font-weight:800;font-size:20px;color:var(--amber);min-width:22px}
.lev-track{flex:1;height:5px;background:var(--s3);border-radius:3px;overflow:hidden;max-width:110px}
.lev-fill{height:100%;border-radius:3px;transition:width .4s var(--ease)}
.lev-lbl{font-size:9px;color:var(--ink3);letter-spacing:.5px}
.sc-btns{display:flex;gap:2px}
.sc-btn{width:20px;height:20px;border-radius:4px;background:var(--s2);border:1px solid var(--line2);color:var(--ink3);font-size:11px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s}
.sc-btn:hover{background:var(--amber-d);color:var(--amber);border-color:var(--amber-b)}

/* Status */
.status-wrap{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.status-badge{display:inline-flex;align-items:center;gap:5px;padding:4px 11px;border-radius:100px;font-size:10px;font-weight:600;border:1px solid;cursor:pointer;transition:all .18s;position:relative;overflow:hidden}
.status-badge::before{content:'';position:absolute;inset:0;background:currentColor;opacity:.07}
.sdot{width:6px;height:6px;border-radius:50%;background:currentColor}
.sdot.pulse{animation:blink 2s infinite;box-shadow:0 0 5px currentColor}
.status-menu{position:absolute;top:calc(100% + 5px);left:0;background:#fff;border:1px solid var(--line2);border-radius:8px;padding:4px;z-index:60;min-width:175px;box-shadow:var(--shadow-md);display:none;flex-direction:column;gap:1px}
.status-menu.open{display:flex;animation:menuIn .12s var(--ease)}
@keyframes menuIn{from{opacity:0;transform:translateY(-4px)}to{opacity:1;transform:translateY(0)}}
.sopt{display:flex;align-items:center;gap:7px;padding:6px 9px;border-radius:5px;font-size:10px;cursor:pointer;transition:background .1s;color:var(--ink2)}
.sopt:hover{background:var(--s2)}
.sopt-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.sopt-desc{font-size:8.5px;color:var(--ink3);margin-left:auto}
.steps{display:flex;align-items:center}
.stp{display:flex;align-items:center}
.stp-dot{width:7px;height:7px;border-radius:50%;border:1.5px solid var(--ink3);transition:all .25s}
.stp-dot.done{background:var(--green);border-color:var(--green);box-shadow:0 0 5px var(--green)}
.stp-dot.active{background:var(--amber);border-color:var(--amber);box-shadow:0 0 6px var(--amber);animation:blink 2s infinite}
.stp-line{width:15px;height:1.5px;background:var(--ink4)}
.stp-line.done{background:var(--green)}

/* Notes */
.notes-wrap{display:flex;flex-direction:column;gap:7px}
.note-compose{display:flex;gap:6px;align-items:flex-start}
.note-input{flex:1;background:var(--s1);border:1px solid var(--line2);border-radius:6px;padding:7px 10px;color:var(--ink);font-family:var(--mono);font-size:11px;outline:none;resize:none;min-height:32px;max-height:80px;line-height:1.5;transition:border-color .15s}
.note-input:focus{border-color:var(--amber)}
.note-input::placeholder{color:var(--ink3)}
.note-add-btn{padding:7px 11px;border-radius:6px;background:var(--amber-d);border:1px solid var(--amber-b);color:var(--amber);font-family:var(--mono);font-size:10px;font-weight:600;cursor:pointer;transition:all .15s;white-space:nowrap;flex-shrink:0}
.note-add-btn:hover{background:rgba(196,123,24,.2);border-color:var(--amber)}
.notes-list{display:flex;flex-direction:column;gap:5px}
.note-item{display:flex;gap:8px;padding:8px 10px;background:var(--s1);border:1px solid var(--line);border-radius:7px;transition:border-color .15s;animation:noteIn .2s var(--ease)}
@keyframes noteIn{from{opacity:0;transform:translateY(-4px)}to{opacity:1;transform:translateY(0)}}
.note-item:hover{border-color:var(--line2)}
.note-item.auto{border-left:2px solid var(--amber-b)}
.note-dot{width:6px;height:6px;border-radius:50%;margin-top:4px;flex-shrink:0}
.note-dot.manual{background:var(--amber)}
.note-dot.auto{background:var(--purple)}
.note-body{flex:1;min-width:0}
.note-text{font-size:11px;color:var(--ink2);line-height:1.6;word-break:break-word}
.note-time{font-size:9px;color:var(--ink3);margin-top:2px}
.note-del{font-size:12px;color:var(--ink3);cursor:pointer;opacity:0;transition:opacity .15s;background:none;border:none;align-self:flex-start;padding:1px 3px}
.note-item:hover .note-del{opacity:1}
.note-del:hover{color:var(--red)}
.notes-empty{font-size:11px;color:var(--ink3)}

/* Actions */
.actions-wrap{display:flex;gap:5px;flex-wrap:wrap}
.ab{display:flex;align-items:center;gap:5px;padding:6px 10px;border-radius:6px;font-family:var(--mono);font-size:10px;font-weight:500;cursor:pointer;transition:all .15s var(--ease);border:1px solid;position:relative;overflow:hidden;letter-spacing:.3px}
.ab:hover{transform:translateY(-1px);box-shadow:0 4px 14px rgba(0,0,0,.12)}
.ab::before{content:'';position:absolute;inset:0;background:currentColor;opacity:0;transition:opacity .15s}
.ab:hover::before{opacity:.06}
.ab-icon,.ab-txt{position:relative;z-index:1}
.ab-kbd{font-size:8px;opacity:.4;position:relative;z-index:1;margin-left:2px}
.ab-r{color:var(--sky);border-color:rgba(22,114,184,.3);background:var(--sky-d)}
.ab-r:hover{border-color:var(--sky)}
.ab-l{color:var(--purple);border-color:rgba(104,64,200,.3);background:var(--purple-d)}
.ab-l:hover{border-color:var(--purple)}
.ab-a{color:var(--green);border-color:rgba(15,138,82,.3);background:var(--green-d)}
.ab-a:hover{border-color:var(--green)}
.ab-c{color:var(--amber);border-color:rgba(196,123,24,.3);background:var(--amber-d)}
.ab-c:hover{border-color:var(--amber)}
.ab-t{color:var(--red);border-color:rgba(184,40,40,.3);background:var(--red-d)}
.ab-t:hover{border-color:var(--red)}

/* Card footer */
.nc-footer{padding:9px 14px;background:#fff;border-top:1px solid var(--line2);display:flex;align-items:center;gap:10px;flex-wrap:wrap;flex-shrink:0}
.nc-fmeta{font-size:9px;color:var(--ink3);display:flex;align-items:center;gap:3px}
.nc-fmeta span{color:var(--ink2)}
.nc-fbtns{margin-left:auto;display:flex;gap:4px}
.nc-fbtn{padding:4px 8px;border-radius:5px;font-family:var(--mono);font-size:9px;cursor:pointer;transition:all .15s;background:var(--s2);border:1px solid var(--line2);color:var(--ink3)}
.nc-fbtn:hover{background:var(--s3);color:var(--ink)}
.nc-fbtn.del{color:var(--red);border-color:rgba(184,40,40,.2)}
.nc-fbtn.del:hover{background:var(--red-d)}
.nc-fbtn.wa{color:var(--green);border-color:rgba(15,138,82,.2)}
.nc-fbtn.wa:hover{background:var(--green-d)}

/* AI output */
.ai-out-wrap{flex-shrink:0;max-height:200px;overflow-y:auto;border-top:1px solid var(--green-d);background:rgba(15,138,82,.03);display:none}
.ai-out-wrap.open{display:block;animation:slideIn .2s var(--ease)}
.ai-out-hdr{padding:8px 13px;border-bottom:1px solid var(--green-d);display:flex;align-items:center;gap:7px;font-size:10px;font-weight:600;color:var(--green);letter-spacing:.8px;flex-shrink:0}
.ai-out-close{margin-left:auto;cursor:pointer;width:19px;height:19px;border-radius:4px;display:flex;align-items:center;justify-content:center;background:var(--s2);border:1px solid var(--line2);color:var(--ink3);font-size:13px;transition:all .15s}
.ai-out-close:hover{color:var(--ink)}
.ai-loading{display:flex;align-items:center;gap:5px;font-size:10px;color:var(--ink3);padding:12px 13px}
.ai-dots span{display:inline-block;width:5px;height:5px;background:var(--green);border-radius:50%;animation:db 1.1s infinite;margin:0 1px}
.ai-dots span:nth-child(2){animation-delay:.18s}
.ai-dots span:nth-child(3){animation-delay:.36s}
@keyframes db{0%,80%,100%{transform:scale(.5);opacity:.35}40%{transform:scale(1);opacity:1}}
.ai-text{font-size:11px;color:var(--ink2);line-height:1.7;white-space:pre-wrap;font-family:var(--mono);padding:12px 13px;display:none}

/* ═══════════════════════════════
   HUB FOOTER
═══════════════════════════════ */
.hub{height:var(--hub-h);min-height:var(--hub-h);background:#fff;border-top:1px solid var(--line2);display:flex;align-items:center;padding:0 12px;gap:4px;overflow-x:auto;z-index:10;position:relative;box-shadow:0 -1px 4px rgba(26,20,16,.04)}
.hub-lbl{font-size:9px;color:var(--ink3);flex-shrink:0;margin-right:3px;letter-spacing:1px;text-transform:uppercase}
.hbtn{display:flex;align-items:center;gap:3px;padding:4px 10px;border-radius:5px;border:1px solid var(--line2);background:transparent;color:var(--ink3);font-family:var(--mono);font-size:10px;cursor:pointer;transition:all .15s;white-space:nowrap}
.hbtn:hover{background:var(--s2);color:var(--ink);border-color:var(--amber-b)}
.hbtn.on{background:var(--amber-d);color:var(--amber);border-color:var(--amber-b)}
.hdiv{width:1px;height:18px;background:var(--line2);flex-shrink:0}
.hub-fb{margin-left:auto;font-size:9px;color:var(--ink3);display:flex;align-items:center;gap:5px;flex-shrink:0}
.fdb{width:5px;height:5px;border-radius:50%;background:var(--green);animation:blink 2s infinite}

/* ═══════════════════════════════
   MODALS
═══════════════════════════════ */
.modal-bg{position:fixed;inset:0;z-index:200;background:rgba(26,20,16,.6);backdrop-filter:blur(8px);display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;pointer-events:none;transition:opacity .2s}
.modal-bg.open{opacity:1;pointer-events:all}
.modal{background:#fff;border:1px solid var(--line2);border-radius:13px;width:100%;max-width:490px;max-height:88vh;overflow-y:auto;padding:24px;transform:translateY(12px) scale(.98);transition:transform .2s var(--ease);box-shadow:var(--shadow-md)}
.modal-bg.open .modal{transform:translateY(0) scale(1)}
.modal-title{font-family:var(--head);font-weight:800;font-size:15px;margin-bottom:16px;color:var(--ink)}
.fg{margin-bottom:13px}
.flbl{font-size:9px;letter-spacing:1.5px;text-transform:uppercase;color:var(--ink3);font-weight:600;margin-bottom:4px;display:block}
.finput,.ftextarea,.fselect{width:100%;background:var(--s1);border:1px solid var(--line2);border-radius:7px;padding:9px 11px;color:var(--ink);font-family:var(--mono);font-size:12px;outline:none;transition:border-color .15s}
.finput:focus,.ftextarea:focus,.fselect:focus{border-color:var(--amber)}
.ftextarea{resize:vertical;min-height:70px;line-height:1.6}
.modal-btns{display:flex;gap:6px;margin-top:16px}
.mbtn{display:flex;align-items:center;gap:5px;padding:7px 14px;border-radius:6px;font-family:var(--mono);font-size:11px;font-weight:500;cursor:pointer;transition:all .15s;border:none}
.mbtn-gold{background:var(--amber);color:#fff;font-weight:700}
.mbtn-gold:hover{background:var(--amber2)}
.mbtn-ghost{background:var(--s2);color:var(--ink2);border:1px solid var(--line2)}
.mbtn-ghost:hover{background:var(--s3)}

/* Settings extras */
.mode-card{padding:12px;border-radius:8px;border:1px solid var(--line2);background:var(--s1);cursor:pointer;text-align:center;transition:all .15s}
.mode-card:hover,.mode-card.mode-active{border-color:var(--amber);background:var(--amber-d);box-shadow:0 0 12px var(--amber-d)}
.callout-s{padding:10px 12px;border-radius:7px;font-size:10.5px;line-height:1.6;margin:9px 0;border:1px solid}
.callout-s.tip{background:var(--sky-d);border-color:rgba(22,114,184,.3);color:var(--ink2)}
.callout-s.note{background:var(--amber-d);border-color:var(--amber-b);color:var(--ink2)}
.conn-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}

/* ═══════════════════════════════
   TOAST + SPIN
═══════════════════════════════ */
.toast{position:fixed;bottom:52px;left:50%;transform:translateX(-50%) translateY(50px);background:#fff;border:1px solid var(--line2);border-radius:8px;padding:9px 16px;font-size:11px;color:var(--ink);z-index:300;transition:transform .2s var(--ease);display:flex;align-items:center;gap:7px;box-shadow:var(--shadow-md)}
.toast.show{transform:translateX(-50%) translateY(0)}
.spin{display:inline-block;width:11px;height:11px;border:1.5px solid rgba(26,20,16,.2);border-top-color:currentColor;border-radius:50%;animation:sp .7s linear infinite}
@keyframes sp{to{transform:rotate(360deg)}}

/* Export overlay */
.export-bg{position:fixed;inset:0;z-index:250;background:rgba(26,20,16,.7);backdrop-filter:blur(12px);display:flex;flex-direction:column;align-items:center;padding:28px 20px;overflow-y:auto;opacity:0;pointer-events:none;transition:opacity .2s}
.export-bg.open{opacity:1;pointer-events:all}
.export-toolbar{width:100%;max-width:580px;display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}
.export-card{width:100%;max-width:580px;background:#fff;border:1px solid var(--line2);border-radius:14px;overflow:hidden;box-shadow:var(--shadow-md)}
.ec-top{padding:24px 26px 18px;border-bottom:1px solid var(--line2);position:relative}
.ec-top::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--amber),var(--amber2),transparent 70%)}
.ec-brand{display:flex;align-items:center;gap:9px;margin-bottom:16px}
.ec-kz{width:28px;height:28px;background:linear-gradient(135deg,var(--amber2),var(--amber));border-radius:6px;display:flex;align-items:center;justify-content:center;font-family:var(--head);font-weight:800;font-size:11px;color:#fff}
.ec-title{font-family:var(--head);font-weight:800;font-size:20px;color:var(--ink);line-height:1.2;margin-bottom:4px}
.ec-hausa{font-family:var(--arab);font-size:16px;color:var(--amber);direction:rtl;margin-bottom:12px;opacity:.9}
.ec-body{padding:20px 26px}
.ec-section-title{font-size:9.5px;text-transform:uppercase;letter-spacing:1.5px;color:var(--ink3);font-weight:600;margin-bottom:7px}
.ec-summary{font-size:13px;color:var(--ink2);line-height:1.75;margin-bottom:18px}
.ec-stat{background:var(--s1);border:1px solid var(--line2);border-radius:8px;padding:12px 14px;text-align:center}
.ec-stat-val{font-family:var(--head);font-weight:800;font-size:20px;color:var(--amber)}
.ec-stat-key{font-size:9px;text-transform:uppercase;letter-spacing:1px;color:var(--ink3);margin-top:2px}
.ec-footer{padding:13px 26px;background:var(--s1);border-top:1px solid var(--line2);display:flex;align-items:center;justify-content:space-between;font-size:10px;color:var(--ink3)}
.ec-watermark{font-family:var(--arab);font-size:14px;color:var(--amber);opacity:.6}

/* Responsive */
@media(max-width:900px){:root{--panel-w:240px}.steps{display:none}}
@media(max-width:640px){.workspace{grid-template-columns:1fr}.panel-left,.panel-right{display:none}}
</style>
</head>
<body>

<!-- ═══════════ NAV ═══════════ -->
<nav class="nav">
  <div class="nav-brand">
    <div class="kz-mark">KZ</div>
    <div>
      <div class="brand-main">KNOWLEDGE GRAPH OS</div>
      <div class="brand-sub">کیمیار ظاہری · v4</div>
    </div>
  </div>
  <div class="nav-pipe">
    <span class="pipe-step done" id="ps-ingest">① INGEST</span><span class="pipe-arrow">→</span>
    <span class="pipe-step" id="ps-embed">② EMBED</span><span class="pipe-arrow">→</span>
    <span class="pipe-step" id="ps-graph">③ GRAPH</span><span class="pipe-arrow">→</span>
    <span class="pipe-step" id="ps-explore">④ EXPLORE</span><span class="pipe-arrow">→</span>
    <span class="pipe-step" id="ps-act">⑤ ACT</span><span class="pipe-arrow">→</span>
    <span class="pipe-step" id="ps-learn">⑥ LEARN</span>
  </div>
  <div class="nav-right">
    <div class="live-dot"></div>
    <div class="nav-stat">Nodes: <b id="statNodes">0</b></div>
    <div class="nav-stat">Edges: <b id="statEdges">0</b></div>
    <div class="nav-stat">Actions: <b id="statActions">0</b></div>
    <button class="nav-btn amber" onclick="openNewModal()">+ Node</button>
    <button class="nav-btn" id="settingsBtn" onclick="openSettings()">⚙ API</button>
  </div>
</nav>

<!-- ═══════════ WORKSPACE ═══════════ -->
<div class="workspace">

  <!-- LEFT PANEL -->
  <div class="panel-left">
    <div class="panel-hdr"><span class="panel-hdr-accent">◈</span> NODES &amp; INGEST</div>
    <div class="panel-body">

      <!-- Search -->
      <div class="search-wrap">
        <span class="search-icon">🔍</span>
        <input class="search-input" id="searchInput" placeholder="Search nodes..." oninput="filterNodes()">
      </div>

      <!-- Filter tabs -->
      <div class="filter-tabs">
        <button class="ftab on" onclick="setFilter(this,'all')">All</button>
        <button class="ftab" onclick="setFilter(this,'tech')">🔬 Tech</button>
        <button class="ftab" onclick="setFilter(this,'trust')">🛡 Trust</button>
        <button class="ftab" onclick="setFilter(this,'transform')">🚀 Transform</button>
        <button class="ftab" onclick="setFilter(this,'insight')">💡 Insight</button>
      </div>

      <div class="nodelist-hdr">
        <span>NODES</span>
        <span id="nodeCount" style="color:var(--amber)">0</span>
      </div>
      <div id="nodeList"></div>

      <div class="divider"></div>

      <!-- Ingest -->
      <div class="ilabel">📄 Paste Text / Idea</div>
      <textarea class="itextarea" id="ingestInput" placeholder="Paste text — AI extracts concepts and adds graph nodes automatically..."></textarea>
      <div class="ilabel" style="margin-top:8px">🏷 Force Tag</div>
      <div class="tag-row">
        <span class="mtag mt-tech" onclick="toggleTag(this,'tech')">🔬 tech</span>
        <span class="mtag mt-trust" onclick="toggleTag(this,'trust')">🛡 trust</span>
        <span class="mtag mt-transform" onclick="toggleTag(this,'transform')">🚀 transform</span>
        <span class="mtag mt-insight" onclick="toggleTag(this,'insight')">💡 insight</span>
      </div>
      <button class="ibtn" id="ingestBtn" onclick="processIngest()">
        <span id="ingestBtnTxt">⚡ PROCESS → GRAPH</span>
      </button>

      <div class="divider"></div>

      <!-- Resources -->
      <div class="res-hdr"><span>📚 RESOURCES</span><span style="color:var(--amber)">3</span></div>
      <div class="res-card" onclick="openResource('https://nitdaacademy.gov.ng')">
        <span class="res-icon">🏛️</span>
        <div>
          <div class="res-name">NITDA Academy</div>
          <div class="res-desc">Free government digital certification — cybersecurity, data governance, cloud basics</div>
          <span class="res-tag">Free · Official · Nigeria</span>
        </div>
      </div>
      <div class="res-card" onclick="openResource('https://startup.google.com/programs/black-founders-fund/africa/')">
        <span class="res-icon">🌍</span>
        <div>
          <div class="res-name">Google for Startups Africa</div>
          <div class="res-desc">$100k+ cloud credits, AI training, mentorship network for African founders</div>
          <span class="res-tag">Free Credits · Google Cloud · Mentorship</span>
        </div>
      </div>
      <div class="res-card" onclick="openResource('https://au.int/en/ea/digital')">
        <span class="res-icon">🤝</span>
        <div>
          <div class="res-name">African Union DTS Framework</div>
          <div class="res-desc">Continental digital transformation strategy 2020-2030 — policy, data sovereignty, infrastructure</div>
          <span class="res-tag">Policy · Pan-African · Official</span>
        </div>
      </div>

    </div>
  </div>

  <!-- CENTER GRAPH -->
  <div class="graph-center">
    <svg id="graphSvg">
      <defs>
        <filter id="glow"><feGaussianBlur stdDeviation="3" result="c"/><feMerge><feMergeNode in="c"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
        <marker id="arr" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
          <path d="M0,0 L0,6 L6,3 z" fill="rgba(196,123,24,.4)"/>
        </marker>
      </defs>
    </svg>
    <div class="graph-empty" id="graphEmpty">
      <div class="graph-empty-icon">🕸</div>
      <div class="graph-empty-txt">Knowledge graph will appear here.<br><br>Click <strong style="color:var(--amber)">Load Seed Data</strong> to start<br>or paste text in the left panel.</div>
    </div>
    <div class="graph-legend">
      <div class="leg-row"><div class="leg-dot" style="background:var(--sky)"></div>Technology</div>
      <div class="leg-row"><div class="leg-dot" style="background:var(--green)"></div>Trust</div>
      <div class="leg-row"><div class="leg-dot" style="background:var(--amber)"></div>Transform</div>
      <div class="leg-row"><div class="leg-dot" style="background:var(--purple)"></div>Insight</div>
    </div>
    <div class="pipe-indicator">
      <div class="pi-title">PIPELINE</div>
      <div class="pi-row"><div class="pidot done" id="pi1"></div><span id="pi1t">Ingest ready</span></div>
      <div class="pi-row"><div class="pidot" id="pi2"></div><span id="pi2t">Embedding</span></div>
      <div class="pi-row"><div class="pidot" id="pi3"></div><span id="pi3t">Building graph</span></div>
      <div class="pi-row"><div class="pidot" id="pi4"></div><span id="pi4t">Linking edges</span></div>
      <div class="pi-row"><div class="pidot" id="pi5"></div><span id="pi5t">AI layer ready</span></div>
    </div>
    <div class="graph-toolbar">
      <button class="tb-btn" onclick="resetZoom()">⊡ Fit</button>
      <button class="tb-btn on" onclick="setLayout('force')" id="tbForce">⬤ Force</button>
      <button class="tb-btn" onclick="setLayout('radial')" id="tbRadial">◎ Radial</button>
      <button class="tb-btn" onclick="clearGraph()">🗑 Clear</button>
    </div>
  </div>

  <!-- RIGHT PANEL -->
  <div class="panel-right">
    <div class="panel-hdr"><span class="panel-hdr-accent">◎</span> NODE DETAIL</div>
    <div class="node-empty" id="nodeEmpty">
      <div class="node-empty-icon">◎</div>
      <span>Click any node to open its detail card</span>
    </div>
    <div class="node-card-wrap" id="nodeCardWrap">

      <div class="nc-header">
        <div class="nc-title-row">
          <div class="nc-glyph" id="ncGlyph">💡</div>
          <div class="nc-title" id="ncTitle" contenteditable="false" spellcheck="false">Node Title</div>
          <button class="edit-btn" id="ncEditBtn" onclick="toggleTitleEdit()" title="Edit">✎</button>
        </div>
        <div class="nc-hausa" id="ncHausaTitle" style="display:none"></div>
        <div class="nc-meta" id="ncMeta"></div>
      </div>

      <div class="nc-body">

        <!-- Summary -->
        <div class="field">
          <div class="field-label"><span class="ficon">💡</span>Summary</div>
          <div class="field-val">
            <textarea class="f-textarea" id="fSummary" readonly rows="3" placeholder="Core idea..."></textarea>
          </div>
        </div>

        <!-- Hausa Translation -->
        <div class="field">
          <div class="field-label"><span class="ficon">🌙</span>Hausa</div>
          <div class="field-val">
            <div class="hausa-field-wrap">
