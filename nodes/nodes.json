/* ══════════════════════════════════════════
   DUPLICATE / DELETE
══════════════════════════════════════════ */
function duplicateActiveNode(){
  const src=getActive(); if(!src) return;
  const W=document.getElementById('graphSvg').clientWidth||800;
  const H=document.getElementById('graphSvg').clientHeight||500;
  const dup={...JSON.parse(JSON.stringify(src)),id:uid(),title:src.title+' (copy)',notes:[{id:uid(),text:`Duplicated from "${src.title}"`,type:'auto',createdAt:new Date().toISOString()}],createdAt:new Date().toISOString(),updatedAt:new Date().toISOString()};
  dup.x=(src.x||400)+60; dup.y=(src.y||300)+60;
  graphData.nodes.push(dup);
  saveGraph(); renderGraph(); renderNodeList(); updateStats(); selectNode(dup.id);
  toast('⧉ Duplicated');
}

function deleteActiveNode(){
  if(!selectedId) return;
  if(graphData.nodes.length===1){toast('⚠ Cannot delete last node');return}
  const n=getActive();
  if(!confirm(`Delete "${n?.title}"?`)) return;
  graphData.nodes=graphData.nodes.filter(x=>x.id!==selectedId);
  graphData.links=graphData.links.filter(l=>(l.source?.id||l.source)!==selectedId&&(l.target?.id||l.target)!==selectedId);
  selectedId=graphData.nodes[0]?.id||null;
  saveGraph(); if(g) g.selectAll('*').remove();
  renderGraph(); renderNodeList(); updateStats();
  if(selectedId) selectNode(selectedId);
  else{document.getElementById('nodeEmpty').style.display='flex';document.getElementById('nodeCardWrap').classList.remove('visible')}
  toast('🗑 Deleted');
}

