   INTERACTIONS
══════════════════════════════════════════ */
let _editing=false;
function toggleTitleEdit(){
  const el=document.getElementById('ncTitle'), btn=document.getElementById('ncEditBtn');
  _editing=!_editing;
  el.contentEditable=_editing?'true':'false';
  btn.textContent=_editing?'✓':'✎';
  btn.style.color=_editing?'var(--green)':'';
  if(_editing){el.focus();const r=document.createRange();r.selectNodeContents(el);window.getSelection().removeAllRanges();window.getSelection().addRange(r)}
  else{const n=getActive();if(!n)return;const t=el.textContent.trim();if(t&&t!==n.title){autoNote(n,`Title: "${n.title}" → "${t}"`);n.title=t}n.updatedAt=new Date().toISOString();renderNodeList();saveGraph();toast('✓ Title saved')}
}

function adjustScore(d){
  const n=getActive(); if(!n) return;
  n.leverage=Math.min(5,Math.max(1,(n.leverage||3)+d));
  n.score=n.leverage;
  n.updatedAt=new Date().toISOString();
  saveGraph(); renderNodeCard(n); renderNodeList();
}

function changeTopic(val){
  const n=getActive(); if(!n) return;
  autoNote(n,`Topic: ${TOPICS[n.category]?.label} → ${TOPICS[val]?.label}`);
  n.category=val; n.updatedAt=new Date().toISOString();
  saveGraph(); renderNodeCard(n); renderNodeList(); renderGraph();
}

function toggleStatusMenu(){ document.getElementById('statusMenu').classList.toggle('open') }

function setStatus(id){
  const n=getActive(); if(!n) return;
  const s=STATUSES.find(s=>s.id===id);
  autoNote(n,`Status → "${s.label}"`);
  n.status=id; n.updatedAt=new Date().toISOString();
  document.getElementById('statusMenu').classList.remove('open');
  saveGraph(); renderNodeCard(n);
  toast(`Status → ${s.label}`);
}

function togglePicker(e){ e.stopPropagation(); document.getElementById('pickerMenu').classList.toggle('open') }

function linkNode(targetId){
  const n=getActive(); if(!n||n.related.includes(targetId)) return;
  n.related.push(targetId);
  graphData.links.push({source:n.id,target:targetId,label:'relates_to',width:1});
  n.updatedAt=new Date().toISOString();
  const rn=getNode(targetId);
  autoNote(n,`Linked → "${rn?.title||targetId}"`);
  renderNodeCard(n); renderNodeList(); renderGraph(); updateStats(); saveGraph();
  toast(`⬡ Linked → ${rn?.title||targetId}`);
}

function unlinkNode(e,targetId){
  e.stopPropagation();
  const n=getActive(); if(!n) return;
  n.related=n.related.filter(id=>id!==targetId);
  graphData.links=graphData.links.filter(l=>{const s=l.source?.id||l.source,t=l.target?.id||l.target;return !((s===n.id&&t===targetId)||(s===targetId&&t===n.id))});
  n.updatedAt=new Date().toISOString();
  autoNote(n,`Unlinked from "${getNode(targetId)?.title||targetId}"`);
  renderNodeCard(n); renderNodeList(); renderGraph(); updateStats(); saveGraph();
  toast('Unlinked');
}

/* ══════════════════════════════════════════
   NOTES
══════════════════════════════════════════ */
function addNote(){
  const input=document.getElementById('noteInput');
  const text=input.value.trim();
  if(!text){toast('⚠ Note is empty');return}
  const n=getActive(); if(!n) return;
  if(!n.notes) n.notes=[];
  n.notes.push({id:uid(),text,type:'manual',createdAt:new Date().toISOString()});
  n.updatedAt=new Date().toISOString();
  input.value='';
  saveGraph(); renderNotes(n); renderNodeList(); toast('📝 Note added');
}

function deleteNote(noteId){
  const n=getActive(); if(!n) return;
  n.notes=(n.notes||[]).filter(note=>note.id!==noteId);
  n.updatedAt=new Date().toISOString();
  saveGraph(); renderNotes(n); renderNodeList();
}

function autoNote(node,text){
  if(!node.notes) node.notes=[];
  node.notes.push({id:uid(),text,type:'auto',createdAt:new Date().toISOString()});
}

function noteKeydown(e){ if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();addNote()} }

