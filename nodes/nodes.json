}
function closeExport(){ document.getElementById('exportBg').classList.remove('open') }

/* ══════════════════════════════════════════
   AI ACTIONS
══════════════════════════════════════════ */
function getApiKey(){ return localStorage.getItem('kz_apikey_v4')||'' }
function getApiEndpoint(){
  const mode=localStorage.getItem('kz_api_mode_v4')||'personal';
  if(mode==='community'){const p=localStorage.getItem('kz_proxy_v4')||'';if(p) return p.replace(/\/$/,'')+'/api/chat'}
  return 'https://api.anthropic.com/v1/messages';
}
function buildHeaders(){
  const h={'Content-Type':'application/json'};
  const mode=localStorage.getItem('kz_api_mode_v4')||'personal';
  if(mode==='personal'){const k=getApiKey();if(k){h['x-api-key']=k;h['anthropic-version']='2023-06-01';h['anthropic-dangerous-direct-browser-access']='true'}}
  return h;
}

async function runAction(type){
  const node=getActive(); if(!node){toast('⚠ Select a node first');return}
  if(currentHub!=='all'&&currentHub!==type) return;
  enrichNode(node);
  const wrap=document.getElementById('aiOutWrap'), ldr=document.getElementById('aiLoading'), txt=document.getElementById('aiText'), lbl=document.getElementById('aiOutLbl');
  lbl.textContent=`● ${ACT_LABELS[type]}`; lbl.style.color=ACT_COLORS[type];
  wrap.classList.add('open'); ldr.style.display='flex'; txt.style.display='none'; txt.textContent='';
  wrap.scrollIntoView({behavior:'smooth',block:'nearest'});
  pipe('act','active'); pipe('learn','active');
  try{
    const nd={title:node.title,summary:node.summary||node.title,topic:TOPICS[node.category]?.label||node.category,status:node.status,score:node.leverage};
    const res=await fetch(getApiEndpoint(),{
      method:'POST', headers:buildHeaders(),
      body:JSON.stringify({
        model:'claude-haiku-4-5-20251001', max_tokens:1000,
        system:`You are the KZ Hub AI — intelligence layer of Kimiyyar Zahiri, a digital education movement for Northern Nigeria founded by Kriptomech. You understand Arewa culture, Hausa context, Nigerian fintech, Web3 in emerging markets, Islamic finance, and digital challenges in Northern Nigeria. Always be specific, actionable, and grounded in real Nigerian context.`,
        messages:[{role:'user',content:ACT_PROMPTS[type](nd)}]
      })
    });
    const data=await res.json();
    if(!res.ok) throw new Error(data.error?.message||`API error ${res.status}`);
    const output=data.content?.[0]?.text||'No response.';
    ldr.style.display='none'; txt.style.display='block'; txt.textContent=output;
    if(!node.actionOutputs) node.actionOutputs={};
    node.actionOutputs[type]={text:output,generatedAt:new Date().toISOString()};
    if(type==='content'||type==='research') node.aiGenerated=true;
    autoNote(node,`AI ${type} action completed`);
    node.updatedAt=new Date().toISOString();
    if(type==='content'||type==='research'){
      const nid=uid();
      const W=document.getElementById('graphSvg').clientWidth||800;
      const H=document.getElementById('graphSvg').clientHeight||500;
      graphData.nodes.push({id:nid,title:ACT_LABELS[type]+': '+node.title.slice(0,25),summary:output.slice(0,200),category:type==='content'?'transform':'insight',leverage:2,score:2,status:'concept',x:(node.x||400)+80,y:(node.y||300)+80,createdAt:new Date().toISOString(),updatedAt:new Date().toISOString(),aiGenerated:true,related:[node.id],notes:[],title_hausa:'',summary_hausa:''});
      graphData.links.push({source:node.id,target:nid,label:'builds_on',width:1});
      renderGraph(); renderNodeList(); updateStats(); feedback('Graph updated from AI action');
    }
    actionCount++; localStorage.setItem('kz_ac_v4',actionCount); updateStats();
    saveGraph(); pipe('act','done'); pipe('learn','done'); renderNodeCard(node);
  }catch(e){
    ldr.style.display='none'; txt.style.display='block';
    txt.textContent='⚠ '+e.message+'\n\nCheck ⚙ API settings and ensure your key is saved.';
  }
}

function closeAiOut(){ document.getElementById('aiOutWrap').classList.remove('open') }

/* ══════════════════════════════════════════
   SETTINGS
══════════════════════════════════════════ */
let _apiMode=localStorage.getItem('kz_api_mode_v4')||'personal';

function openSettings(){
  document.getElementById('sApiKey').value=getApiKey();
  document.getElementById('sProxyUrl').value=localStorage.getItem('kz_proxy_v4')||'';
  setApiMode(_apiMode,false); updateConnStatus();
  document.getElementById('settingsModal').classList.add('open');
}
function closeSettings(){ document.getElementById('settingsModal').classList.remove('open') }
function closeSettingsBg(e){ if(e.target===e.currentTarget) closeSettings() }

function setApiMode(mode,save=true){
  _apiMode=mode;
  document.getElementById('modePersonal').classList.toggle('mode-active',mode==='personal');
  document.getElementById('modeCommunity').classList.toggle('mode-active',mode==='community');
  document.getElementById('sPersonalFields').style.display=mode==='personal'?'block':'none';
  document.getElementById('sCommunityFields').style.display=mode==='community'?'block':'none';
  document.getElementById('sStatus').style.display='none';
  if(save) localStorage.setItem('kz_api_mode_v4',mode);
}

function saveSettings(){
  const key=document.getElementById('sApiKey').value.trim();
  const proxy=document.getElementById('sProxyUrl').value.trim();
  if(_apiMode==='personal'&&!key){showSettingsStatus('⚠ Paste your Anthropic API key','warn');return}
  if(_apiMode==='community'&&!proxy){showSettingsStatus('⚠ Paste your proxy URL','warn');return}
  localStorage.setItem('kz_api_mode_v4',_apiMode);
  localStorage.setItem('kz_apikey_v4',key);
  localStorage.setItem('kz_proxy_v4',proxy);
  updateConnStatus(); closeSettings(); toast('✓ Settings saved');
}

async function testConnection(){
  const btn=document.getElementById('testBtnTxt');
  btn.innerHTML='<span class="spin" style="color:var(--amber)"></span>';
  showSettingsStatus('Testing...','tip');
  try{
    const res=await fetch(getApiEndpoint(),{method:'POST',headers:buildHeaders(),body:JSON.stringify({model:'claude-haiku-4-5-20251001',max_tokens:10,messages:[{role:'user',content:'Say: ok'}]})});
    const data=await res.json();
    if(data?.content?.[0]?.text||data?.id) showSettingsStatus('✅ Connected! AI features working.','win');
    else if(data?.error) showSettingsStatus('❌ '+data.error?.message,'warn');
    else showSettingsStatus('⚠ Unexpected response','warn');
  }catch(e){showSettingsStatus('❌ Could not connect — check URL or key','warn')}
  btn.textContent='↗ Test';
}

function showSettingsStatus(msg,type){
  const el=document.getElementById('sStatus'); el.style.display='block'; el.textContent=msg;
  const styles={tip:`background:var(--sky-d);border:1px solid rgba(22,114,184,.3);color:var(--sky)`,win:`background:var(--green-d);border:1px solid rgba(15,138,82,.3);color:var(--green)`,warn:`background:var(--red-d);border:1px solid rgba(184,40,40,.3);color:var(--red)`};
  el.setAttribute('style',`display:block;padding:9px 12px;border-radius:7px;font-size:11px;${styles[type]||styles.tip}`);
}

function updateConnStatus(){
  const dot=document.getElementById('connDot'), msg=document.getElementById('connMsg'), btn=document.getElementById('settingsBtn');
  const mode=localStorage.getItem('kz_api_mode_v4')||'personal';
  const key=getApiKey(), proxy=localStorage.getItem('kz_proxy_v4')||'';
  if(mode==='personal'&&key){
    dot.style.background='var(--green)';dot.style.boxShadow='0 0 6px var(--green)';
    msg.style.color='var(--green)'; msg.textContent='🔑 Personal key configured'; btn.style.color='var(--green)';
  } else if(mode==='community'&&proxy){
    dot.style.background='var(--sky)';dot.style.boxShadow='0 0 6px var(--sky)';
    msg.style.color='var(--sky)'; msg.textContent='🌐 Proxy: '+proxy.replace('https://','').split('/')[0]; btn.style.color='var(--sky)';
  } else {
    dot.style.background='var(--red)';dot.style.boxShadow='none';
    msg.style.color='var(--ink3)'; msg.textContent='Not configured — click ⚙ API to set up'; btn.style.color='var(--red)';
  }
}

/* ══════════════════════════════════════════
   INGEST PIPELINE
══════════════════════════════════════════ */
async function processIngest(){
  const text=document.getElementById('ingestInput').value.trim();
  if(!text){toast('Paste some text first!');return}
  if(!getApiKey()){toast('⚠ Set API key in ⚙ API settings first');openSettings();return}
  const btn=document.getElementById('ingestBtn'), btxt=document.getElementById('ingestBtnTxt');
  btn.disabled=true; btxt.innerHTML='<span class="spin" style="color:#fff"></span> PROCESSING...';
  pipe('ingest','done'); pipe('embed','active'); pi(2,'active');
  await delay(350);
  pi(2,'done'); pi(3,'active'); pipe('embed','done'); pipe('graph','active');
  try{
    const existing=graphData.nodes.map(n=>n.title).join(', ');
    const res=await fetch(getApiEndpoint(),{
      method:'POST', headers:buildHeaders(),
      body:JSON.stringify({
        model:'claude-haiku-4-5-20251001', max_tokens:1000,
        system:`You are a semantic knowledge extractor for Kimiyyar Zahiri, a digital education movement for Northern Nigeria. Extract structured knowledge graph data. Return ONLY valid JSON, no markdown:\n{"nodes":[{"id":"slug","title":"Short title (max 5 words)","summary":"2-3 sentence explanation in Northern Nigeria context","category":"tech|trust|transform|insight","tags":["tag1"],"weight":1-5}],"links":[{"from":"id","to":"id","label":"relates_to|enables|builds_on|requires|addresses"}]}\nExtract 3-7 key concepts. Existing nodes: ${existing||'none'}.`,
        messages:[{role:'user',content:`Extract knowledge graph from:\n\n${text}`}]
      })
    });
    const data=await res.json();
    if(!res.ok) throw new Error(data.error?.message||`Error ${res.status}`);
    const clean=(data.content?.[0]?.text||'{}').replace(/```json|```/g,'').trim();
    const ext=JSON.parse(clean);
    await delay(300); pi(3,'done'); pi(4,'active');
    const W=document.getElementById('graphSvg').clientWidth||800;
    const H=document.getElementById('graphSvg').clientHeight||500;
    let addedCount=0;
    (ext.nodes||[]).forEach(n=>{
      if(!graphData.nodes.find(e=>e.id===n.id)){
        if(forceTag) n.category=forceTag;
        n.x=Math.random()*(W-200)+100; n.y=Math.random()*(H-200)+100;
        n.leverage=n.weight||3; n.score=n.leverage; n.notes=[]; n.title_hausa=''; n.summary_hausa='';
        enrichNode(n); graphData.nodes.push(n); addedCount++;
      }
    });
    (ext.links||[]).forEach(l=>{
      const ex=graphData.links.find(e=>(e.source===l.from&&e.target===l.to)||(e.source===l.to&&e.target===l.from)||((e.source?.id||e.source)===l.from&&(e.target?.id||e.target)===l.to));
      if(!ex) graphData.links.push({source:l.from,target:l.to,label:l.label||'relates_to',width:1});
    });
    await delay(300); pi(4,'done'); pi(5,'active'); pipe('graph','done'); pipe('explore','active');
    saveGraph(); renderGraph(); renderNodeList(); updateStats();
    await delay(400); pi(5,'done'); pipe('explore','done'); pipe('act','active');
    document.getElementById('graphEmpty').style.display='none';
    document.getElementById('ingestInput').value='';
    forceTag=null; document.querySelectorAll('.mtag').forEach(t=>t.classList.remove('sel'));
    feedback(`+${addedCount} concept${addedCount!==1?'s':''} extracted`);
    toast(`✓ ${addedCount} concept${addedCount!==1?'s':''} added to graph`);
  }catch(e){
    toast('⚠ '+e.message);
    ['embed','graph'].forEach(s=>pipe(s,''));
  }finally{
    btn.disabled=false; btxt.innerHTML='⚡ PROCESS → GRAPH';
  }
}

/* ══════════════════════════════════════════
   D3 GRAPH
══════════════════════════════════════════ */
function initSvg(){
  svg=d3.select('#graphSvg');
  g=svg.append('g').attr('class','graph-g');
  const zoom=d3.zoom().scaleExtent([.12,3]).on('zoom',e=>g.attr('transform',e.transform));
  svg.call(zoom); svg._zoom=zoom;
}

function renderGraph(){
  if(!svg) initSvg();
  g.selectAll('*').remove();
  const nodes=graphData.nodes.map(n=>({...n}));
  const links=graphData.links.map(l=>({...l}));
  if(!nodes.length) return;
  const W=document.getElementById('graphSvg').clientWidth||800;
  const H=document.getElementById('graphSvg').clientHeight||500;
  const nodeMap={}; nodes.forEach(n=>nodeMap[n.id]=n);
  const resolved=links.filter(l=>{const s=l.source?.id||l.source,t=l.target?.id||l.target;return nodeMap[s]&&nodeMap[t]}).map(l=>({...l,source:nodeMap[l.source?.id||l.source],target:nodeMap[l.target?.id||l.target]}));
  if(sim) sim.stop();
  sim=d3.forceSimulation(nodes)
    .force('link',d3.forceLink(resolved).id(d=>d.id).distance(130).strength(.4))
    .force('charge',d3.forceManyBody().strength(-300))
    .force('center',d3.forceCenter(W/2,H/2))
    .force('collide',d3.forceCollide().radius(d=>nR(d)+24));
  const lkColors={relates_to:CAT_COLORS.tech,enables:CAT_COLORS.trust,builds_on:CAT_COLORS.transform,requires:CAT_COLORS.insight,affects:'#888',implements:'#888',supports:'#888',drives:'#888',serves:'#888',addresses:CAT_COLORS.trust,regulates:CAT_COLORS.insight,governs:CAT_COLORS.insight,underpins:CAT_COLORS.tech};
  const lkEl=g.append('g').selectAll('line').data(resolved).enter().append('line')
    .attr('class','link').style('stroke',d=>lkColors[d.label]||'#aaa').style('stroke-dasharray',d=>d.label==='requires'||d.label==='governs'?'4,3':null);
  const nEl=g.append('g').selectAll('.node').data(nodes).enter().append('g')
    .attr('class','node').style('cursor','pointer')
    .call(d3.drag().on('start',(e,d)=>{if(!e.active)sim.alphaTarget(.3).restart();d.fx=d.x;d.fy=d.y}).on('drag',(e,d)=>{d.fx=e.x;d.fy=e.y}).on('end',(e,d)=>{if(!e.active)sim.alphaTarget(0);d.fx=null;d.fy=null}))
    .on('click',(e,d)=>{e.stopPropagation();selectNode(d.id)});
  // is-new marker
  nEl.each(function(d){
    const isNew=d.createdAt&&(Date.now()-new Date(d.createdAt).getTime())<86400000*7;
    if(isNew) d3.select(this).append('circle').attr('r',d=>nR(d)+13).style('fill','none').style('stroke',CAT_COLORS[d.category]||'#aaa').style('stroke-width',.8).style('stroke-dasharray','2,2').style('opacity',.35);
  });
  // glow ring
  nEl.append('circle').attr('r',d=>nR(d)+8).style('fill',d=>CAT_COLORS[d.category]||'#aaa').style('opacity',.07);
  // main circle
  nEl.append('circle').attr('r',d=>nR(d))
    .style('fill',d=>CAT_COLORS[d.category]||'#aaa').style('fill-opacity',.18)
    .style('stroke',d=>CAT_COLORS[d.category]||'#aaa').style('stroke-opacity',.9).attr('filter','url(#glow)');
  // label
  nEl.append('text').attr('dy',d=>nR(d)+13).attr('text-anchor','middle')
    .style('font-size',d=>d.leverage>=4?'10.5px':'9.5px').style('fill',d=>CAT_COLORS[d.category]).style('font-weight','600')
    .text(d=>d.title.length>18?d.title.slice(0,16)+'…':d.title);
  nEl.style('opacity',0).transition().duration(500).delay((_,i)=>i*40).style('opacity',1);
  sim.on('tick',()=>{
    lkEl.attr('x1',d=>d.source.x).attr('y1',d=>d.source.y).attr('x2',d=>d.target.x).attr('y2',d=>d.target.y);
    nEl.attr('transform',d=>`translate(${d.x},${d.y})`);
  });
  if(selectedId) setTimeout(()=>highlightNode(selectedId),700);
}

function nR(d){ return 10+(d.leverage||d.weight||1)*3 }

function highlightNode(id){
  if(!g) return;
  g.selectAll('.node').selectAll('circle:nth-child(2)')
    .style('stroke-width',d=>d.id===id?3:1.8).style('fill-opacity',d=>d.id===id?.32:.18);
  g.selectAll('.link')
    .style('stroke-opacity',d=>(d.source.id===id||d.target.id===id)?.85:.15)
    .style('stroke-width',d=>(d.source.id===id||d.target.id===id)?2.5:1.5);
}

function resetZoom(){
  if(!svg) return;
  const W=document.getElementById('graphSvg').clientWidth||800, H=document.getElementById('graphSvg').clientHeight||500;
  svg.transition().duration(450).call(svg._zoom.transform,d3.zoomIdentity.translate(W/2,H/2).scale(.8).translate(-W/2,-H/2));
}

function setLayout(type){
  document.getElementById('tbForce').classList.toggle('on',type==='force');
  document.getElementById('tbRadial').classList.toggle('on',type==='radial');
  if(!sim) return;
  const W=document.getElementById('graphSvg').clientWidth||800, H=document.getElementById('graphSvg').clientHeight||500;
  if(type==='radial') sim.force('center',d3.forceRadial(Math.min(W,H)/3,W/2,H/2).strength(.8));
  else sim.force('center',d3.forceCenter(W/2,H/2));
  sim.alpha(.5).restart();
}

/* ══════════════════════════════════════════
   MODALS / CONTROLS
══════════════════════════════════════════ */
function openNewModal(){ document.getElementById('newModal').classList.add('open') }
function closeModal(){ document.getElementById('newModal').classList.remove('open') }
function closeMBg(e){ if(e.target===e.currentTarget) closeModal() }

function createManualNode(){
  const title=document.getElementById('mTitle').value.trim();
  if(!title){toast('⚠ Title is required');return}
  const W=document.getElementById('graphSvg').clientWidth||800, H=document.getElementById('graphSvg').clientHeight||500;
  const n={id:uid(),title,summary:document.getElementById('mSummary').value.trim()||title,category:document.getElementById('mTopic').value,tags:[],leverage:parseInt(document.getElementById('mScore').value)||3,score:parseInt(document.getElementById('mScore').value)||3,status:'concept',related:[],notes:[{id:uid(),text:'Node created manually',type:'auto',createdAt:new Date().toISOString()}],title_hausa:'',summary_hausa:'',x:Math.random()*(W-200)+100,y:Math.random()*(H-200)+100,createdAt:new Date().toISOString(),updatedAt:new Date().toISOString(),aiGenerated:false};
  graphData.nodes.push(n);
  saveGraph(); renderGraph(); renderNodeList(); updateStats(); closeModal(); selectNode(n.id);
  ['mTitle','mSummary'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('graphEmpty').style.display='none';
  toast(`✦ Node: ${title}`);
}

function setHub(el,hub){
  document.querySelectorAll('.hub .hbtn').forEach(b=>b.classList.remove('on'));
  el.classList.add('on'); currentHub=hub;
}

function clearGraph(){
  if(!confirm('Clear the entire knowledge graph?')) return;
  graphData={nodes:[],links:[]}; saveGraph();
  if(g) g.selectAll('*').remove();
  document.getElementById('graphEmpty').style.display='flex';
  document.getElementById('nodeEmpty').style.display='flex';
  document.getElementById('nodeCardWrap').classList.remove('visible');
  selectedId=null; renderNodeList(); updateStats();
  ['ingest','embed','graph','explore','act','learn'].forEach(s=>pipe(s,s==='ingest'?'done':''));
  [1,2,3,4,5].forEach(n=>pi(n,n===1?'done':''));
  feedback('Graph cleared');
}

function exportGraph(){
  const b=new Blob([JSON.stringify(graphData,null,2)],{type:'application/json'});
  const a=document.createElement('a'); a.href=URL.createObjectURL(b);
  a.download='kz-graph-v4-'+new Date().toISOString().slice(0,10)+'.json'; a.click();
  toast('↗ JSON exported');
}

function toggleTag(el,tag){
  document.querySelectorAll('.mtag').forEach(t=>t.classList.remove('sel'));
  forceTag=forceTag===tag?null:tag;
  if(forceTag) el.classList.add('sel');
}

/* ══════════════════════════════════════════
   SEED DATA LOADER
══════════════════════════════════════════ */
function loadSeed(){
  if(graphData.nodes.length>0&&!confirm('Load seed data? This will add 14 nodes to your current graph.')) return;
  const W=document.getElementById('graphSvg').clientWidth||800;
  const H=document.getElementById('graphSvg').clientHeight||500;
  const existingIds=new Set(graphData.nodes.map(n=>n.id));
  SEED.nodes.forEach(n=>{
    if(!existingIds.has(n.id)){
      n.x=Math.random()*(W-200)+100; n.y=Math.random()*(H-200)+100;
      n.score=n.leverage; n.notes=n.notes||[];
      if(!n.createdAt) n.createdAt=new Date().toISOString();
      if(!n.updatedAt) n.updatedAt=new Date().toISOString();
      enrichNode(n); graphData.nodes.push(n);
    }
  });
  SEED.edges.forEach(l=>{
    const ex=graphData.links.find(e=>{const s=e.source?.id||e.source,t=e.target?.id||e.target;return (s===l.from&&t===l.to)||(s===l.to&&t===l.from)});
    if(!ex) graphData.links.push({source:l.from,target:l.to,label:l.label,width:l.width||1});
  });
  saveGraph(); renderGraph(); renderNodeList(); updateStats();
  document.getElementById('graphEmpty').style.display='none';
  [1,2,3,4,5].forEach(n=>pi(n,'done'));
  ['ingest','embed','graph','explore','act'].forEach(s=>pipe(s,'done'));
  feedback('Seed loaded — 14 nodes: 9 original + 5 new infrastructure skills');
  toast('✓ Seed data loaded — 14 knowledge nodes ready');
  setTimeout(()=>selectNode('arewa-digital-youth'),700);
}

/* ══════════════════════════════════════════
   KEYBOARD SHORTCUTS
══════════════════════════════════════════ */
document.addEventListener('keydown',e=>{
  const active=document.activeElement;
  const typing=active.tagName==='INPUT'||active.tagName==='TEXTAREA'||active.contentEditable==='true';
  if(e.key==='Escape'){closeModal();closeSettings();closeExport();closeAiOut();document.getElementById('statusMenu').classList.remove('open');document.getElementById('pickerMenu')?.classList.remove('open')}
  if(!typing){
    if((e.metaKey||e.ctrlKey)&&e.key==='s'){e.preventDefault();const n=getActive();if(n){n.summary=document.getElementById('fSummary').value;n.updatedAt=new Date().toISOString();saveGraph();toast('✓ Saved')}}
    if((e.metaKey||e.ctrlKey)&&e.key==='Enter') processIngest();
    const map={r:'research',l:'learn',a:'automate',c:'content',t:'track'};
    if(map[e.key.toLowerCase()]){e.preventDefault();runAction(map[e.key.toLowerCase()])}
  }
});

document.addEventListener('click',e=>{
  if(!document.getElementById('statusRing')?.contains(e.target)) document.getElementById('statusMenu')?.classList.remove('open');
  const pm=document.getElementById('pickerMenu');
  if(pm&&!document.getElementById('pickerWrap')?.contains(e.target)) pm.classList.remove('open');
});

/* ══════════════════════════════════════════
   INIT
══════════════════════════════════════════ */
window.addEventListener('DOMContentLoaded',()=>{
  initSvg();
  updateConnStatus();
  graphData.nodes.forEach(n=>enrichNode(n));
  updateStats();
  renderNodeList();
  if(graphData.nodes.length>0){
    renderGraph();
    document.getElementById('graphEmpty').style.display='none';
    [1,2,3,4,5].forEach(n=>pi(n,'done'));
    ['ingest','embed','graph','explore'].forEach(s=>pipe(s,'done'));
    setTimeout(()=>selectNode(graphData.nodes[0].id),400);
  }
});

window.addEventListener('resize',()=>{if(graphData.nodes.length) renderGraph()});
</script>
